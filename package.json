{
  "name": "@recost-dev/node",
  "version": "0.1.2",
  "description": "ReCost middleware for Node.js — provider registry, interceptors, and framework adapters",
  "license": "BUSL-1.1",
  "author": "recost-dev",
  "type": "module",
  "main": "dist/index.js",
  "module": "./dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:types": "tsc --emitDeclarationOnly --outDir dist/types",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/recost-dev/node-sdk"
  },
  "homepage": "https://recost.dev",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ws": "^8.19.0"
  }
}
